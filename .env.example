# Google Drive API Configuration
# Used by Homepage.vue for invitation verification
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your-api-key-here

# SSL Configuration Strategy
# devcert: Automatically generate and trust local certs (Dev only)
# production: Use manual paths provided below
# none: Fallback to standard HTTP
SSL_STRATEGY=devcert

# Manual SSL Paths (Required if SSL_STRATEGY=production)
SSL_KEY_PATH=./ssl/localhost.key
SSL_CERT_PATH=./ssl/localhost.crt

# Firebase Configuration
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Backend Server Configuration
PORT=3000