<table border="0" cellpadding="0" cellspacing="0" role="presentation" style="border-collapse:separate;line-height:100%;">
  <tr>
    <td align="center" bgcolor="{{#if color}}{{color}}{{else}}#007bff{{/if}}" role="presentation" style="border:none;border-radius:3px;cursor:auto;padding:10px 25px;background:{{#if color}}{{color}}{{else}}#007bff{{/if}};" valign="middle">
      <a href="{{url}}" style="background:{{#if color}}{{color}}{{else}}#007bff{{/if}};color:#ffffff;font-family:sans-serif;font-size:14px;font-weight:bold;line-height:120%;margin:0;text-decoration:none;text-transform:none;" target="_blank">
        {{text}}
      </a>
    </td>
  </tr>
</table>