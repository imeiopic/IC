{
  "name": "iopic-substrate",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npm run dev:all-concurrent",
    "clean": "rimraf node_modules/.vite dist .turbo",
    "type-check": "vue-tsc -p tsconfig.app.json --noEmit --skipLibCheck",
    "build": "npm run build:functions && npm run build:browser && npm run wasm:optimize",
    "build:functions": "tsc -p tsconfig.functions.json --outDir dist/functions",
    "build:browser": "vite build --config vite.config.ts --outDir dist/browser",
    "wasm:optimize": "tsx scripts/optimize-wasm.ts",
    "deploy": "firebase deploy --only functions,hosting",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.vue --fix"
  },
  "dependencies": {
    "@coreui/coreui": "^5.6.1",
    "@coreui/vue": "^5.8.0",
    "@faker-js/faker": "^10.4.0",
    "@google-cloud/vision": "^5.3.6",
    "@googlemaps/js-api-loader": "^2.1.1",
    "@sentry/vue": "^8.20.0",
    "@stripe/stripe-js": "^9.5.0",
    "body-parser": "^2.2.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "busboy": "^1.6.0",
    "chart.js": "^4.4.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "face-api.js": "^0.22.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "lru-cache": "^11.3.5",
    "mermaid": "^11.14.0",
    "mitt": "^3.0.1",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.5",
    "pinia": "^3.0.4",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "qrcode.vue": "^3.9.0",
    "signal-cli": "^0.13.19",
    "three": "^0.184.0",
    "vue": "^3.4.0",
    "vue-chartjs": "^5.3.1",
    "vue-pdf-embed": "^2.1.4",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.1.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/busboy": "^1.5.4",
    "@types/gapi": "^0.0.47",
    "@types/google.maps": "^3.65.2",
    "@types/leaflet": "^1.9.12",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^1.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "devcert": "^1.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "fireback": "^0.1.6",
    "jsdom": "^29.1.0",
    "lint-staged": "^15.2.2",
    "mocha": "^11.7.5",
    "ncp": "^2.0.0",
    "patch-package": "^8.0.0",
    "postcss": "^8.4.38",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.7",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "^1.100.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5",
    "vite": "^6.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-sass-dts": "1.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^1.5.0",
    "wait-on": "^7.2.0",
    "wasm-opt": "^1.3.0"
  }
}
