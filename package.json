{
  "name": "iopic-functions",
  "description": "Cloud Functions for Iopic Substrate",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "@coreui/coreui": "^5.6.1",
    "@coreui/vue": "^5.8.0",
    "@google-cloud/vision": "^5.3.6",
    "body-parser": "^2.2.2",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.4.2",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "face-api.js": "^0.22.2",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^6.0.0",
    "lru-cache": "^11.3.5",
    "mermaid": "^11.14.0",
    "mitt": "^3.0.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.5",
    "pinia": "^3.0.4",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "qrcode.vue": "^3.9.0",
    "sass": "^1.99.0",
    "three": "^0.184.0",
    "vue": "^3.4.0",
    "vue-chartjs": "^5.3.1",
    "vue-pdf-embed": "^2.1.4",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.2",
    "@playwright/test": "^1.43.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^1.5.0",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "devcert": "^1.2.2",
    "eslint": "^8.57.0",
    "fireback": "^0.1.6",
    "firebase-functions-test": "^3.1.0",
    "jsdom": "^29.1.0",
    "lint-staged": "^15.2.2",
    "mocha": "^11.7.5",
    "ncp": "^2.0.0",
    "patch-package": "^8.0.0",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.7",
    "rollup-plugin-visualizer": "^5.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^6.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-sass-dts": "1.3.2",
    "vitest": "^1.5.0",
    "wait-on": "^7.2.0"
  },
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "postinstall": "patch-package",
    "dev:all": "node start-dev.js",
    "dev:all-concurrent": "concurrently --kill-others -n \"BACKEND,FRONTEND\" -c \"bgBlue,bgGreen\" \"npm run dev:backend-internal\" \"wait-on tcp:5000 && cross-env VITE_FIREBACK_PORT=5000 npm run dev:frontend\"",
    "dev:all-concurrent-http": "concurrently --kill-others -n \"BACKEND,FRONTEND\" -c \"bgBlue,bgGreen\" \"cross-env-shell fireback serve --port 5000\" \"wait-on tcp:5000 && cross-env VITE_FIREBACK_PORT=5000 npm run dev:frontend\"",
    "dev:backend-internal": "node -e \"require('child_process').spawnSync(process.platform === 'win32' ? 'fireback.cmd' : 'fireback', ['serve', '--port', '5000', '--ssl-key', process.env.FIREBACK_SSL_KEY_PATH, '--ssl-cert', process.env.FIREBACK_SSL_CERT_PATH], {stdio:'inherit', cwd: process.cwd()})\"",
    "dev:frontend": "vite",
    "clean": "npx kill-port 5000 5173 && rimraf node_modules/.vite",
    "emulators:debug": "firebase emulators:start --inspect-functions --only functions,firestore,auth --import=./emulator_data --export-on-exit=./emulator_data",
    "emulators:start": "firebase emulators:start --only functions,firestore,auth --import=./emulator_data --export-on-exit=./emulator_data",
    "emulators:export": "firebase emulators:export ./emulator_data",
    "emulators:clean-start": "rimraf ./emulator_data && ncp ./emulator_data_clean_source ./emulator_data && npm run emulators:start",
    "emulators:seed-start": "rimraf ./emulator_data && ncp ./emulator_data_seed ./emulator_data && npm run emulators:start",
    "emulators:reseed": "firebase emulators:exec --only auth,firestore 'ts-node seed-emulator.ts && firebase emulators:export ./emulator_data_seed --force'",
    "seed": "ts-node seed-emulator.ts",
    "emulators:start-auto-seed": "concurrently -n \"EMU,SEED\" -c \"bgBlue,bgGreen\" \"npm run emulators:start\" \"wait-on tcp:127.0.0.1:8080 && npm run seed\"",
    "heartbeat": "ts-node IopicGlobalHeartbeat.ts",
    "backup:volume": "bash scripts/backup-volume.sh",
    "test:rules": "firebase emulators:exec --only firestore,storage,auth \"vitest run --project rules\"",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "build:preview": "npm run build && npm run preview",
    "build:emu": "cross-env VITE_USE_FIREBASE_EMULATOR=true npm run build",
    "build:preview:emu": "npm run build:emu && npm run preview",
    "backfill": "node backfill-daily-stats.js -p calcium-channel-489906-m2",
    "backfill:emu": "node backfill-daily-stats.js -p calcium-channel-489906-m2 --use-emulator",
    "grant-claim": "node grant-system-claim.js -p calcium-channel-489906-m2",
    "grant-claim:emu": "node grant-system-claim.js -p calcium-channel-489906-m2 --use-emulator",
    "test:unit": "vitest",
    "test:unit:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update-snapshots": "playwright test --update-snapshots"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,css,scss,html}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "vite-plugin-sass-dts": {
      "vite": "$vite"
    }
  }
}
