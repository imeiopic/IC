const router = createRouter({
  history: createWebHistory(),
  routes
});

/**
 * THE SOVEREIGN HANDSHAKE (Navigation Guard)
 * Logic: Policing transits between Public Noise and the Grounded Mesh
 */
router.beforeEach(async (to, from, next) => {
  const { ensureAuthInitialized } = useAuth();
  const user = await ensureAuthInitialized();
  const requiresAuth = to.matched.some((record) => record.meta.requiresAuth);

  // 1. Unauthenticated Block: Protect the Mesh
  if (requiresAuth && !user) {
    return next('/');
  }

  // 2. Referral Sighting: Intercept Incoming Pulses
  if (to.query.ref) {
    sessionStorage.setItem('referrer_instance_id', to.query.ref as string);
    // Force transition to onboarding if authenticated to ground the fee
    if (user && to.name !== 'Onboarding') {
      return next({ name: 'Onboarding' });
    }
  }

  // 3. Logic Clear
  next();
});

export default router;