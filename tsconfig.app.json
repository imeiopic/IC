{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "*.ts", "*.tsx", "*.vue", "*.js"],
  "exclude": ["node_modules", "dist", "src/**/__tests__/*", "functions/**/*", "tests/**/*", "e2e/**/*"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@assets/*": ["./src/assets/*"],
      "@views/*": ["./src/views/*"],
      "@composables/*": ["./src/composables/*"],
      "@services/*": ["./src/services/*"],
      "@components/*": ["./src/components/*"],
      "@stores/*": ["./src/stores/*"]
    },
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "resolveJsonModule": true,
    "skipLibCheck": true
  }
}